# ════════════════════════════════════════════════
#  MC Panel — Environment Variables
# ════════════════════════════════════════════════

# ── PANEL SERVICE ────────────────────────────────
PANEL_PASSWORD=your_password_here
RAILWAY_API_TOKEN=from_railway_account_settings
RAILWAY_PROJECT_ID=from_railway_project_url
RAILWAY_MC_SERVICE_ID=from_mc_service_settings
RAILWAY_ENVIRONMENT_ID=from_railway_environments_tab
SIDECAR_URL=http://mc-server.railway.internal:8080
SIDECAR_SECRET=make_up_random_string
MC_HOST=your_mc_service_tcp_proxy_domain
MC_PORT=25565

# ── MC SERVER SERVICE ────────────────────────────
SIDECAR_SECRET=same_random_string_as_panel
PANEL_API_URL=https://your-panel.up.railway.app
RCON_PASSWORD=make_up_random_string
RCON_PORT=25575
MC_VERSION=latest
MC_MEMORY=2G
MC_MOTD=My Server
MC_MAX_PLAYERS=20
MC_DIFFICULTY=normal
MC_GAMEMODE=survival
MC_ONLINE_MODE=true
MC_PVP=true
AUTO_SHUTDOWN_MINUTES=30
